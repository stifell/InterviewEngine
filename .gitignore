.env

# Аудио-/видео-записи интервью — PII + большой размер, не коммитим.
# Папку сохраняем через .gitkeep, сами записи держим только локально.
samples/audio/*
!samples/audio/.gitkeep

# Java / Maven
target/
*.class
*.jar
*.war
*.ear
*.nar
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

#  Node.js / npm 
node_modules/
dist/
*.local

#  Python 
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.Python

#  Ollama модели
ollama-models/

#  IDE 
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

#  Логи 
*.log
logs/
