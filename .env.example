# LLM (бэкенд) 
# Ключ Google AI Studio: https://aistudio.google.com/ → Create API Key
GEMINI_API_KEY=AIza...

# ── Python sidecar (ASR + диаризация + просодика) 
# Токен HuggingFace для pyannote (диаризация моно-записей): https://huggingface.co/settings/tokens
# Нужен только для моно-аудио; для стерео/раздельных каналов можно не задавать.
HUGGINGFACE_TOKEN=hf_...
# Размер модели: tiny | base | small | medium | large-v3 | large-v3-turbo
WHISPER_MODEL=large-v3-turbo
# cuda — если есть NVIDIA GPU; cpu — иначе
WHISPER_DEVICE=cpu
# float16 только для GPU; на CPU ставить int8 (экономит RAM, качество чуть хуже)
WHISPER_COMPUTE_TYPE=int8

# ── PostgreSQL (только для Docker; локальный профиль local использует H2) ──────
POSTGRES_DB=interviewengine
POSTGRES_USER=interviewengine
POSTGRES_PASSWORD=changeme

# ── Ollama (локальный LLM, альтернатива Gemini) ──
OLLAMA_MODELS_DIR=./ollama-models
